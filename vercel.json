{
  "rewrites": [
    {
      "source": "/pricing/",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing/index.html"
    },
    {
      "source": "/review",
      "destination": "/api/review-redirect"
    },
    {
      "source": "/fb",
      "destination": "/api/fb-redirect"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    }
  ],
  "redirects": [
    {
      "source": "/messenger",
      "destination": "https://m.me/61588215297678",
      "permanent": false
    },
    {
      "source": "/chat",
      "destination": "https://m.me/61588215297678",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.handyandfriend.com"
        }
      ],
      "destination": "https://handyandfriend.com/$1",
      "permanent": true
    }
  ]
}
